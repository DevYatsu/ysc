// Functions

fun greet(name) {
  ret "Hello, " + name
}

print(greet("Yatsu"))

fun add(a, b) {
  ret a + b
}

sum = add(3, 4)
print("3 + 4 = " + str(sum))

// Note: type annotations (a: int) are parsed but ignored at runtime
fun multiply(a, b) {
  ret a * b
}

print("6 * 7 = " + str(multiply(6, 7)))
