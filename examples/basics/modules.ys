// Modules: imports and exports
//
// YatsuScript uses Rust-style module paths with DOT separators.
// Each .ys file is a module. Directory structure maps to module paths:
//
//   src/
//   ├── main.ys           // entry point
//   ├── utils/
//   │   ├── parse.ys      // module: utils.parse
//   │   └── format.ys     // module: utils.format
//   └── models/
//       └── user.ys       // module: models.user

// Import a module — brings its top-level items into scope
use utils.parse
use utils.format

// Import a specific item from a module
use utils.parse.parse_line

// Items marked `exp` are visible to importing modules
exp fun public_api() {
  "this is visible to importers"
}

fun internal_helper() {
  "this is private to this module"
}

// Exported variables
exp VERSION = "1.0.0"
exp MAX_SIZE = 1000
