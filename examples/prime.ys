ANSWER = 78498
MAX = 1000000
is_prime = []
is_prime.pad(MAX + 1, true)
is_prime[0] = false
is_prime[1] = false
total = 0
for p in 2 .. MAX + 1 {
  if is_prime[p] {
    total = total + 1
    step = p
    i = p + p
    while i < MAX + 1 {
      is_prime[i] = false
      i = i + step
    }
  }
}
print ( "Total " + str ( total) + " primes <= " + str ( MAX))
if total != ANSWER {
  print ( "The answer is WRONG! Should be " + str ( ANSWER) + "!")
}
