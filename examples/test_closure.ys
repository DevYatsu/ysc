// Test: basic closure with captured variable
fun make_counter() {
  count = 0
  fun increment() {
    count = count + 1
    return count
  }
  return increment()
}
print(make_counter())
print(make_counter())

// Test: closure capturing a parameter
fun make_adder(n) {
  fun add(m) {
    return m + n
  }
  return add(5)
}
print(make_adder(10))

// Test: closure modifying outer scope variable
x = 100
fun modify() {
  x = x + 1
  return x
}
print(modify())
print(x)

if x == 101 {
  print("CLOSURE SUCCESS")
}
